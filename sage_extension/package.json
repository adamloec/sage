{
  "name": "sage-extension",
  "displayName": "Sage",
  "publisher": "Sage",
  "description": "Sage coding assistant extension for VSCode",
  "icon": "images/logo.jpg",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sage.installBackend",
        "title": "Sage: Install Backend"
      },
      {
        "command": "sage.openPanel",
        "title": "Sage: Open Assistant Panel"
      }
    ],
    "keybindings": [
      {
        "command": "sage.openPanel",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ]
  },
  "dependencies": {
    "python-shell": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamloec/sage.git"
  }
}
